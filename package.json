{
  "name": "fit-quest",
  "version": "1.0.0",
  "description": "Offline-first fitness RPG PWA for local workout tracking, adventure battles, XP, profiles, and progress analytics.",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
